# ─── Docker Compose Production ─────────────────────────────────────────────
# Copy this to .env and fill in the values

# ─── Database (REQUIRED) ───────────────────────────────────────────────────
DB_PASSWORD=your_secure_db_password_here
DB_DATABASE=vectoria
DB_USERNAME=admin

# ─── Redis (REQUIRED) ──────────────────────────────────────────────────────
REDIS_PASSWORD=your_secure_redis_password_here

# ─── Frontend ──────────────────────────────────────────────────────────────
NEXT_PUBLIC_API_URL=/api

# ─── App (REQUIRED) ────────────────────────────────────────────────────────
APP_KEY=                          # Generate with: php artisan key:generate
APP_PORT=8080
FRONTEND_URL=https://vectoria.carbonick.com
SANCTUM_STATEFUL_DOMAINS=localhost,localhost:3000,127.0.0.1,vectoria.carbonick.com
APP_ENV=production
LOG_LEVEL=warning                 # Use 'debug' only in development

# ─── Mail (REQUIRED for notifications) ─────────────────────────────────────
MAIL_MAILER=log                   # smtp, postmark, log
MAIL_HOST=smtp.mailtrap.org
MAIL_PORT=2525
MAIL_USERNAME=
MAIL_PASSWORD=
MAIL_ENCRYPTION=tls
MAIL_FROM_ADDRESS=noreply@vectoria.carbonick.com
MAIL_FROM_NAME="Vectoria Rent Car"

# ─── Stripe (optional) ─────────────────────────────────────────────────────
STRIPE_PUBLISHABLE_KEY=
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=

# ─── CMI Maroc (optional) ──────────────────────────────────────────────────
CMI_CLIENT_ID=
CMI_STORE_KEY=
CMI_TEST_MODE=true

# ─── Twilio SMS (optional) ─────────────────────────────────────────────────
TWILIO_AUTH_TOKEN=
TWILIO_PHONE_NUMBER=

# ─── WhatsApp (optional) ───────────────────────────────────────────────────
WHATSAPP_TOKEN=
WHATSAPP_PHONE_NUMBER_ID=
WHATSAPP_API_VERSION=v19.0

# ─── S3 Backups (optional — enables off-site backup) ───────────────────────
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_URL=
AWS_ENDPOINT=
AWS_USE_PATH_STYLE_ENDPOINT=false

# ─── Caddy TLS (optional — uncomment caddy service in docker-compose.prod) ─
# DOMAIN=vectoria.carbonick.com
# EMAIL=your@email.com
