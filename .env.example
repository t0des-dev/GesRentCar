# ─── Docker Compose Production ─────────────────────────────────────────────
# Copy this to .env and fill in the values

# ─── Database (REQUIRED) ───────────────────────────────────────────────────
DB_PASSWORD=your_secure_db_password_here
DB_DATABASE=vectoria
DB_USERNAME=admin

# ─── Redis (REQUIRED) ──────────────────────────────────────────────────────
REDIS_PASSWORD=your_secure_redis_password_here

# ─── Frontend ──────────────────────────────────────────────────────────────
NEXT_PUBLIC_API_URL=/api

# ─── App ───────────────────────────────────────────────────────────────────
APP_PORT=8080
FRONTEND_URL=https://vectoria.carbonick.com
SANCTUM_STATEFUL_DOMAINS=localhost,localhost:3000,127.0.0.1,vectoria.carbonick.com

# ─── Stripe (optional — disabled for now) ──────────────────────────────────
STRIPE_PUBLISHABLE_KEY=
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=

# ─── Caddy TLS (optional — uncomment caddy service in docker-compose.prod) ─
# DOMAIN=vectoria.carbonick.com
# EMAIL=your@email.com
